import pytest
import base64
import json
from io import BytesIO
from PIL import Image
 
 
# helper
def make_base64_image(width=100, height=100, color=(255, 0, 0)):
    img = Image.new("RGB", (width, height), color=color)
    buffer = BytesIO()
    img.save(buffer, format="JPEG")
    encoded = base64.b64encode(buffer.getvalue()).decode("utf-8")
    return f"data:image/jpeg;base64,{encoded}"
 
 
# 1. TEST: Base64 image validation
#   Verifies that incoming image data from the frontend is valid

class TestBase64ImageValidation:
 
    def test_valid_base64_image(self):
        # Normal case: a properly formed base64 data URL should pass
        image_data = make_base64_image()
        assert image_data.startswith("data:image/jpeg;base64,")
        _, encoded = image_data.split(",", 1)
        decoded = base64.b64decode(encoded)
        assert len(decoded) > 0
 
    def test_missing_prefix(self):
        # Edge case: data URL without the "data:image/..." prefix
        raw_base64 = base64.b64encode(b"not a real image").decode("utf-8")
        assert not raw_base64.startswith("data:image/")
 
    def test_empty_image_string(self):
        # Error case: empty string should not be treated as valid image data
        image_data = ""
        assert image_data == "" or not image_data.startswith("data:image/")
 
 

# 2. TEST: Photo count validation
#    Verifies that the photo count passed from the previous page
#    is a usable integer

class TestPhotoCountValidation:
 
    def test_valid_photo_count(self):
        # Normal case: a typical selection like 4 photos
        count = int("4")
        assert count > 0
        assert isinstance(count, int)
 
    def test_minimum_photo_count(self):
        # Edge case: 1 photo should be valid (minimum allowed)
        count = int("1")
        assert count == 1
 
    def test_invalid_photo_count_string(self):
        # Error case: non-numeric value should raise ValueError
        with pytest.raises(ValueError):
            int("abc")
 
    def test_zero_photo_count(self):
        # Edge case: 0 should not trigger any photo captures
        count = int("0")
        assert count == 0  # loop `for i in range(0)` will not run
 
 

# 3. TEST: /stripselect/take_photos route
#    Verifies the POST endpoint that receives captured photos

class TestTakePhotosRoute:
 
    @pytest.fixture
    def client(self):
        # Import here so the test file doesn't hard-fail if app isn't set up yet
        from main import app
        app.config["TESTING"] = True
        with app.test_client() as client:
            yield client
 
    def test_valid_photo_post(self, client):
        # Normal case: sending a valid base64 image returns 200
        payload = {"image": make_base64_image()}
        response = client.post(
            "/stripselect/take_photos",
            data=json.dumps(payload),
            content_type="application/json"
        )
        assert response.status_code == 200
 
    def test_missing_image_key(self, client):
        # Error case: payload without "image" key should return 400
        payload = {"not_image": "some_data"}
        response = client.post(
            "/stripselect/take_photos",
            data=json.dumps(payload),
            content_type="application/json"
        )
        assert response.status_code in (400, 422)
 
    def test_empty_payload(self, client):
        # Error case: completely empty body should not crash the server
        response = client.post(
            "/stripselect/take_photos",
            data="",
            content_type="application/json"
        )
        assert response.status_code in (400, 415, 422, 500)
 

# 4. TEST: Image storage (in-session photo list)
#    Verifies that captured photos accumulate correctly

class TestPhotoStorage:
 
    def test_photos_append_correctly(self):
        # Normal case: photos are added to the list in order
        captured_photos = []
        for i in range(4):
            captured_photos.append(make_base64_image(color=(i * 50, 0, 0)))
        assert len(captured_photos) == 4
 
    def test_photos_are_unique(self):
        # Edge case: different colored images should not be identical
        photo1 = make_base64_image(color=(255, 0, 0))
        photo2 = make_base64_image(color=(0, 255, 0))
        assert photo1 != photo2
 
    def test_empty_photo_list_at_start(self):
        # Normal case: photo list starts empty before session begins
        captured_photos = []
        assert len(captured_photos) == 0
 
    def test_does_not_exceed_photo_count(self):
        # Edge case: should never store more photos than requested
        PHOTO_COUNT = 3
        captured_photos = []
        for i in range(PHOTO_COUNT):
            captured_photos.append(make_base64_image())
        assert len(captured_photos) <= PHOTO_COUNT
 
 

# 5. TEST: Countdown timer logic
#    Verifies the countdown sequence produces the right values

class TestCountdownLogic:
 
    def test_countdown_sequence(self):
        # Normal case: countdown from 3 should produce [3, 2, 1]
        start = 3
        ticks = list(range(start, 0, -1))
        assert ticks == [3, 2, 1]
 
    def test_countdown_ends_at_zero(self):
        # Edge case: final tick should reach 0 and stop
        start = 3
        ticks = list(range(start, -1, -1))
        assert ticks[-1] == 0
 
    def test_single_second_countdown(self):
        # Edge case: countdown starting at 1 should only tick once
        start = 1
        ticks = list(range(start, 0, -1))
        assert ticks == [1]
        assert len(ticks) == 1
 
    def test_countdown_does_not_go_negative(self):
        # Error case: countdown should stop at 0, never go below
        start = 3
        ticks = list(range(start, 0, -1))
        assert all(t > 0 for t in ticks)
